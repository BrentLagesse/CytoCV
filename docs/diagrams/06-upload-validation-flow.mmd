%%{init: {"theme":"base","themeVariables":{"background":"#ffffff","primaryColor":"#f8fafc","primaryBorderColor":"#94a3b8","primaryTextColor":"#0f172a","secondaryColor":"#eff6ff","tertiaryColor":"#eef2ff","lineColor":"#475569","fontFamily":"Helvetica","fontSize":"16px","clusterBorder":"#cbd5e1","clusterBkg":"#ffffff"},"flowchart":{"htmlLabels":true,"curve":"linear","nodeSpacing":28,"rankSpacing":42}}}%%
flowchart TD
    classDef actor fill:#fff7ed,stroke:#fb923c,color:#9a3412,stroke-width:1.4px;
    classDef process fill:#f8fafc,stroke:#94a3b8,color:#0f172a,stroke-width:1.2px;
    classDef decision fill:#fef3c7,stroke:#f59e0b,color:#92400e,stroke-width:1.2px;
    classDef data fill:#ecfdf5,stroke:#4ade80,color:#166534,stroke-width:1.2px;
    classDef warn fill:#fef2f2,stroke:#f87171,color:#991b1b,stroke-width:1.2px;
    classDef output fill:#eef2ff,stroke:#818cf8,color:#3730a3,stroke-width:1.2px;

    start[Experiment POST]
    input[New files and<br/>restored queue UUIDs]
    select[Normalize plugins and<br/>required channels]
    create[Create UploadedImage row<br/>for each new file]
    validate[Recognized DV,<br/>layer count, wavelengths]
    ok{Valid?}
    reject[Delete invalid run and<br/>collect error message]
    scale[Extract scale metadata]
    channels[Extract channel map]
    config[channel_config.json]
    preview[Generate preview PNGs]
    queue[Add UUID to active queue]
    redirect[Redirect to preprocess]

    start --> input --> select --> create --> validate --> ok
    ok -- no --> reject
    ok -- yes --> scale --> channels --> config --> preview --> queue --> redirect

    class start,input actor
    class select,create,validate,scale,channels,preview,queue process
    class ok decision
    class config data
    class reject warn
    class redirect output

flowchart TD
    classDef source fill:#fff7ed,stroke:#fb923c,color:#9a3412,stroke-width:1.4px;
    classDef process fill:#f8fafc,stroke:#94a3b8,color:#0f172a,stroke-width:1.2px;
    classDef data fill:#ecfdf5,stroke:#4ade80,color:#166534,stroke-width:1.2px;
    classDef output fill:#eef2ff,stroke:#818cf8,color:#3730a3,stroke-width:1.2px;

    inputs[DV stack, mask.tif,<br/>channel config]
    outline[Build full-frame overlays<br/>for each channel]
    crops[Save per-cell masks,<br/>outlined crops, and no-outline crops]
    stats[Loop over cells and<br/>compute statistics]
    persist[Update SegmentedImage<br/>and CellStatistics]
    cleanup[Drop transient preview<br/>and preprocess assets]
    review[Display-ready outputs]

    inputs --> outline --> crops --> stats --> persist --> cleanup --> review

    class inputs source
    class outline,crops,stats,cleanup process
    class persist data
    class review output


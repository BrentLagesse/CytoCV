# CytoCV environment variable template.
# Usage:
# 1) Copy this file to `.env` in the repo root.
# 2) Fill in real secrets in `.env` only.
# 3) Do not commit `.env` to git.
#
# Notes:
# - `1` means true/enabled, `0` means false/disabled.
# - Comma-separated lists must not include spaces unless intentional.
# - Leave provider credentials blank to keep that provider unavailable.

# -----------------------------------------------------------------------------
# Core Django settings
# -----------------------------------------------------------------------------
# Required in production. Use a long random string.
CYTOCV_SECRET_KEY=change-me
# Development default: 1. Set to 0 in production.
CYTOCV_DEBUG=1
# Comma-separated hostnames (no protocol, no ports).
# Example: localhost,127.0.0.1,app.example.org
CYTOCV_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Google OAuth (optional)
# -----------------------------------------------------------------------------
# OAuth client ID from Google Cloud Console.
CYTOCV_GOOGLE_CLIENT_ID=
# OAuth client secret from Google Cloud Console.
CYTOCV_GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Microsoft OAuth (optional)
# -----------------------------------------------------------------------------
# App registration client ID from Microsoft Entra/Azure portal.
CYTOCV_MICROSOFT_CLIENT_ID=
# App registration client secret from Microsoft Entra/Azure portal.
CYTOCV_MICROSOFT_CLIENT_SECRET=
# Tenant selector. Common values: organizations, common, or a tenant GUID.
CYTOCV_MICROSOFT_TENANT=organizations
# Microsoft identity endpoint base URL.
CYTOCV_MICROSOFT_LOGIN_URL=https://login.microsoftonline.com

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# SMTP host.
CYTOCV_EMAIL_HOST=smtp.gmail.com
# SMTP username (often full email address).
CYTOCV_EMAIL_HOST_USER=
# SMTP password or app password.
CYTOCV_EMAIL_HOST_PASSWORD=
# Default sender for system emails.
CYTOCV_DEFAULT_FROM_EMAIL=no-reply@noreply.x.edu
# Reply-To header for system emails.
CYTOCV_EMAIL_REPLY_TO=no-reply@noreply.x.edu

# -----------------------------------------------------------------------------
# Google reCAPTCHA (optional)
# -----------------------------------------------------------------------------
# Enable CAPTCHA validation in auth flows.
CYTOCV_RECAPTCHA_ENABLED=0
# Site key used by frontend widget.
CYTOCV_RECAPTCHA_SITE_KEY=
# Secret key used by backend verification.
CYTOCV_RECAPTCHA_SECRET_KEY=
# Verification endpoint. Keep default unless explicitly testing alternatives.
CYTOCV_RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
# Security toggle: keep 0 unless you intentionally allow non-default verify URL.
CYTOCV_RECAPTCHA_ALLOW_VERIFY_URL_OVERRIDE=0
# Expected hostnames in reCAPTCHA token (comma-separated).
CYTOCV_RECAPTCHA_EXPECTED_HOSTNAMES=localhost,127.0.0.1

# Core Django settings
CYTOCV_SECRET_KEY=change-me
CYTOCV_DEBUG=1
CYTOCV_ALLOWED_HOSTS=localhost,127.0.0.1

# Google OAuth
CYTOCV_GOOGLE_CLIENT_ID=
CYTOCV_GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
CYTOCV_MICROSOFT_CLIENT_ID=
CYTOCV_MICROSOFT_CLIENT_SECRET=
CYTOCV_MICROSOFT_TENANT=organizations
CYTOCV_MICROSOFT_LOGIN_URL=https://login.microsoftonline.com

# Microsoft ADFS (legacy / optional)
CYTOCV_ADFS_AUDIENCE=
CYTOCV_ADFS_CLIENT_ID=
CYTOCV_ADFS_CLIENT_SECRET=
CYTOCV_ADFS_TENANT_ID=
CYTOCV_ADFS_RELYING_PARTY_ID=

# Email
CYTOCV_EMAIL_HOST=smtp.gmail.com
CYTOCV_EMAIL_HOST_USER=
CYTOCV_EMAIL_HOST_PASSWORD=
CYTOCV_DEFAULT_FROM_EMAIL=no-reply@noreply.x.edu
CYTOCV_EMAIL_REPLY_TO=no-reply@noreply.x.edu

# Google reCAPTCHA
CYTOCV_RECAPTCHA_ENABLED=0
CYTOCV_RECAPTCHA_SITE_KEY=
CYTOCV_RECAPTCHA_SECRET_KEY=
CYTOCV_RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
CYTOCV_RECAPTCHA_ALLOW_VERIFY_URL_OVERRIDE=0
CYTOCV_RECAPTCHA_EXPECTED_HOSTNAMES=localhost,127.0.0.1
